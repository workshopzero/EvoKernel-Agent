# =========================================================
# Evo-Cognition Kernel (ECK) Configuration Template
# =========================================================
# [ZH] 请将此文件重命名为 .env 并填入你的实际参数
# [EN] Please rename this file to .env and fill in your actual parameters

# --- Google Vertex AI 配置 / Google Vertex AI Config ---
# [ZH] 你的 GCP 项目 ID
# [EN] Your GCP Project ID
GOOGLE_PROJECT_ID=my-gpt-480808
# [ZH] 你的地区 (例如 us-central1)
# [EN] Your Location (e.g., us-central1)
GOOGLE_LOCATION=us-central1
# [ZH] 默认云端模型名称
# [EN] Default Cloud Model Name
GOOGLE_MODEL_NAME=gemini-2.5-flash

# --- 本地模型配置 / Local Model Config (Ollama/vLLM) ---
# [ZH] 宿主机 IP (需确保虚拟机/Docker能ping通)
# [EN] Host IP (Ensure VM/Docker can reach it, e.g., http://127.0.0.1:11434/v1)
HOST_LLM_API_BASE=http://192.168.2.13:11434/v1
# [ZH] 本地 API Key (Ollama 默认填 ollama)
# [EN] Local API Key (Ollama usually accepts 'ollama' or any string)
HOST_LLM_API_KEY=ollama
# [ZH] 本地模型名称
# [EN] Local Model Name
LOCAL_MODEL_NAME=qwen2.5:7b

# --- 系统运行参数 / System Execution Parameters ---
# [ZH] 默认系统运行模式 (auto / local / cloud / offline)
# [EN] Default Execution Mode (auto / local / cloud / offline)
DEFAULT_EXECUTION_MODE=auto
# [ZH] 默认大模型发散度 (0.0 到 1.0)
# [EN] Default LLM Temperature (0.0 to 1.0)
DEFAULT_TEMPERATURE=0.5

# --- 极客与安全配置 / Geek & Security Options ---
# [ZH] 是否允许系统自我修改内核源码？(True/False)
# [EN] Allow system to modify its own kernel source code? (True/False)
ALLOW_SELF_MODIFICATION=True

# [ZH] 是否开启人工确权拦截？(执行代码前需人工按 y 确认)
# [EN] Require human confirmation before executing generated code? (True/False)
REQUIRE_HUMAN_CONFIRMATION=True

# [ZH] 极客选项：代码报错或被 AST 拦截时，是否允许大模型在后台自动反思并重写？
# [EN] Enable auto-reflection and bug fixing when code crashes? (True/False)
ENABLE_INTERNAL_REFLECTION=False

# [ZH] 动态路由开关：(True 允许在本地/云端断网时自动切换补救，False 严格锁定单模型)
# [EN] Enable Dynamic Routing (Failover between Cloud/Local on connection error)
ENABLE_DYNAMIC_ROUTING=True

# --- 语音模块 / Voice Module ---
# [ZH] 语音模块开关 (当前为预留接口)
# [EN] Enable Voice Module (TTS placeholder)
ENABLE_VOICE_MODULE=False

# --- 潜意识引擎 / Subconscious Engine (Background Dreaming) ---
# [ZH] 潜意识作息表: OFF(关闭), ALWAYS(全天候), 或时间段(如 00:00-06:00,12:00-14:00)
# [EN] Subconscious Schedule: OFF, ALWAYS, or Time Range (e.g., 00:00-06:00)
SUBCONSCIOUS_SCHEDULE=ALWAYS
# [ZH] 后台做梦时的全局 CPU 熔断线 (%)，超过此值系统继续睡觉不抢算力
# [EN] Max Global CPU % for background tasks (System stops dreaming if exceeded)
MAX_BACKGROUND_CPU_PERCENT=60